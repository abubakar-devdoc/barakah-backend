NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# PostgreSQL — use the restricted barakah_app role (NOT postgres / BYPASSRLS).
# Example (password URL-encoded): postgresql://barakah_app:CHANGE_ME@db.PROJECT.supabase.co:5432/postgres
DATABASE_URL=postgresql://barakah_app:CHANGE_ME@127.0.0.1:5432/barakah
DATABASE_SSL=false
DATABASE_POOL_MAX=20

# JWT — generate long random secrets (do not reuse exposed keys)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_ISSUER=barakah-api
JWT_AUDIENCE=barakah-clients

# Refresh tokens (opaque, hashed at rest)
REFRESH_TOKEN_EXPIRES_DAYS=30
REFRESH_COOKIE_NAME=barakah_refresh
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAME_SITE=lax
REFRESH_COOKIE_PATH=/api/v1/auth

# bcrypt
BCRYPT_ROUNDS=12

# CORS — comma-separated origins (include frontend dev ports)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# OpenAPI / Swagger
SWAGGER_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Cron
CRON_ENABLED=true
CRON_RECONCILE_SCHEDULE=*/5 * * * *
# Required on Vercel (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Bootstrap (optional one-time seed via script — never commit real values)
BOOTSTRAP_SUPER_ADMIN_EMAIL=
BOOTSTRAP_SUPER_ADMIN_PASSWORD=
